# Se autocopia en la carpeta /sbin
# Asigna permisos de ejecución chmod 777 apagar

#!/bin/sh

# Configuración de seguridad
set -f  # Desactivar globbing
umask 077

# Función para limpiar de forma segura
clean_dir() {
    if [ -d "$1" ]; then
        rm -rf "$1" 2>/dev/null
    fi
}

clean_file() {
    if [ -f "$1" ]; then
        rm -f "$1" 2>/dev/null
    fi
}

clean_file ~/.zsh_history
clean_file ~/.bash_history
clean_file ~/.sh_history
clean_file ~/.python_history
clean_file ~/.node_repl_history
clean_file ~/.sqlite_history
clean_file ~/.mysql_history
clean_file ~/.recently-used
clean_file ~/.local/share/recently-used.xbel

# Truncar históricos (por si existen)
for hist in ~/.zsh_history ~/.bash_history ~/.sh_history ~/.python_history; do
    if [ -f "$hist" ]; then
        > "$hist" 2>/dev/null
    fi
done
clean_dir ~/.mozilla/firefox
clean_dir ~/.cache/mozilla
clean_dir ~/.cache/google-chrome
clean_dir ~/.cache/chromium

# Limpiar manualmente directorios de Firefox si existen
find ~/.mozilla/firefox -type d -name "*.default-release" 2>/dev/null | while read dir; do
    [ -d "$dir/storage/default" ] && rm -rf "$dir/storage/default"
    [ -d "$dir/datareporting" ] && rm -rf "$dir/datareporting"
done
clean_dir ~/.cache
clean_dir ~/.thumbnails
clean_dir ~/.local/share/Trash
clean_dir ~/.local/share/RecentDocuments
clean_dir ~/.kde/share/apps/RecentDocuments
clean_dir ~/.docker
clean_file ~/.docker/config.json

# Limpiar directorios de sesión
clean_file ~/.xsession-errors
find ~/.xsession-errors* -type f -delete 2>/dev/null
clean_file ~/.ssh/known_hosts
find ~/.gnupg -name '*~' -type f -delete 2>/dev/null
clean_dir ~/.local/share/mail
clean_dir ~/.config/google-chrome/Default/Service\ Worker
clean_dir ~/.config/chromium/Default/Service\ Worker
if [ "$(id -u)" -eq 0 ]; then
    rm -rf /tmp/* /var/tmp/* 2>/dev/null
    rm -f /var/lib/systemd/coredump/* 2>/dev/null
    rm -f /var/core /*.core /core 2>/dev/null
    find /var -name "*lock*" -type f -delete 2>/dev/null
else
    sudo rm -rf /tmp/* /var/tmp/* 2>/dev/null
    sudo rm -f /var/lib/systemd/coredump/* 2>/dev/null
    sudo rm -f /var/core /*.core /core 2>/dev/null
    sudo find /var -name "*lock*" -type f -delete 2>/dev/null
fi
if [ "$(id -u)" -eq 0 ]; then
    # APT (Debian/Ubuntu)
    if command -v apt-get >/dev/null 2>&1; then
        apt-get clean 2>/dev/null
        rm -rf /var/cache/apt/archives/*.deb 2>/dev/null
        rm -rf /var/cache/apt/*.bin 2>/dev/null
    fi
    
    # YUM (RHEL/Fedora)
    if command -v yum >/dev/null 2>&1; then
        yum clean all 2>/dev/null
        rm -rf /var/cache/yum/* 2>/dev/null
    fi
    
    # PACMAN (Arch)
    if command -v pacman >/dev/null 2>&1; then
        pacman -Scc --noconfirm 2>/dev/null
        rm -rf /var/cache/pacman/pkg/* 2>/dev/null
    fi
else
    # Con sudo
    if command -v apt-get >/dev/null 2>&1; then
        sudo apt-get clean 2>/dev/null
        sudo rm -rf /var/cache/apt/archives/*.deb 2>/dev/null
        sudo rm -rf /var/cache/apt/*.bin 2>/dev/null
    fi
    
    if command -v yum >/dev/null 2>&1; then
        sudo yum clean all 2>/dev/null
        sudo rm -rf /var/cache/yum/* 2>/dev/null
    fi
    
    if command -v pacman >/dev/null 2>&1; then
        sudo pacman -Scc --noconfirm 2>/dev/null
        sudo rm -rf /var/cache/pacman/pkg/* 2>/dev/null
    fi
fi
if [ "$(id -u)" -eq 0 ]; then
    # Limpiar journalctl
    journalctl --vacuum-time=1s 2>/dev/null
    rm -rf /var/log/journal/* 2>/dev/null
    
    # Truncar archivos de log
    find /var/log -type f -name "*.log" -exec truncate -s 0 {} \; 2>/dev/null
    truncate -s 0 /var/log/auth.log 2>/dev/null
    truncate -s 0 /var/log/syslog 2>/dev/null
    truncate -s 0 /var/log/kern.log 2>/dev/null
    truncate -s 0 /var/log/dmesg 2>/dev/null
    truncate -s 0 /var/log/btmp 2>/dev/null
    truncate -s 0 /var/log/faillog 2>/dev/null
    truncate -s 0 /var/log/tallylog 2>/dev/null
    
    # Eliminar logs comprimidos
    find /var/log -type f \( -name "*.gz" -o -name "*.log.*" -o -name "*.1" -o -name "*.old" \) -delete 2>/dev/null
    
    # Sobrescribir logs sensibles (si existen)
    if command -v shred >/dev/null 2>&1; then
        shred -n 7 -z -u /var/log/wtmp 2>/dev/null || true
        shred -n 7 -z -u /var/log/lastlog 2>/dev/null || true
        shred -n 7 -z /var/log/auth.log.* 2>/dev/null || true
        shred -n 7 -z /var/log/syslog.* 2>/dev/null || true
    fi
    
    # Recrear archivos de log vacíos
    > /var/log/wtmp 2>/dev/null || true
    > /var/log/lastlog 2>/dev/null || true
    > /var/log/btmp 2>/dev/null || true
    
    # Establecer permisos
    chmod 640 /var/log/auth.log 2>/dev/null || true
    chmod 640 /var/log/syslog 2>/dev/null || true
else
    # Con sudo
    sudo journalctl --vacuum-time=1s 2>/dev/null
    sudo rm -rf /var/log/journal/* 2>/dev/null
    sudo find /var/log -type f -name "*.log" -exec truncate -s 0 {} \; 2>/dev/null
    sudo truncate -s 0 /var/log/auth.log 2>/dev/null
    sudo truncate -s 0 /var/log/syslog 2>/dev/null
    sudo truncate -s 0 /var/log/kern.log 2>/dev/null
    sudo truncate -s 0 /var/log/dmesg 2>/dev/null
    sudo truncate -s 0 /var/log/btmp 2>/dev/null
    sudo truncate -s 0 /var/log/faillog 2>/dev/null
    sudo truncate -s 0 /var/log/tallylog 2>/dev/null
    sudo find /var/log -type f \( -name "*.gz" -o -name "*.log.*" -o -name "*.1" -o -name "*.old" \) -delete 2>/dev/null
    
    if command -v shred >/dev/null 2>&1; then
        sudo shred -n 7 -z -u /var/log/wtmp 2>/dev/null || true
        sudo shred -n 7 -z -u /var/log/lastlog 2>/dev/null || true
        sudo shred -n 7 -z /var/log/auth.log.* 2>/dev/null || true
        sudo shred -n 7 -z /var/log/syslog.* 2>/dev/null || true
    fi
    
    sudo sh -c '> /var/log/wtmp 2>/dev/null || true'
    sudo sh -c '> /var/log/lastlog 2>/dev/null || true'
    sudo sh -c '> /var/log/btmp 2>/dev/null || true'
    sudo chmod 640 /var/log/auth.log 2>/dev/null || true
    sudo chmod 640 /var/log/syslog 2>/dev/null || true
fi
if [ "$(id -u)" -eq 0 ]; then
    # Limpiar caché systemd-resolve
    if command -v systemd-resolve >/dev/null 2>&1; then
        systemd-resolve --flush-caches 2>/dev/null
    fi
    
    # Limpiar caché nscd
    rm -f /var/cache/nscd/* 2>/dev/null
    
    # Limpiar caché de memoria si hay suficiente libre
    free_mem=$(free | awk '/^Mem:/ {print $4}')
    total_mem=$(free | awk '/^Mem:/ {print $2}')
    if [ "$total_mem" -gt 0 ]; then
        ratio=$((free_mem * 100 / total_mem))
        if [ "$ratio" -gt 20 ]; then
            sync 2>/dev/null
            echo 3 | tee /proc/sys/vm/drop_caches >/dev/null 2>&1
        fi
    fi
else
    sudo systemd-resolve --flush-caches 2>/dev/null || true
    sudo rm -f /var/cache/nscd/* 2>/dev/null
    
    free_mem=$(free | awk '/^Mem:/ {print $4}')
    total_mem=$(free | awk '/^Mem:/ {print $2}')
    if [ "$total_mem" -gt 0 ]; then
        ratio=$((free_mem * 100 / total_mem))
        if [ "$ratio" -gt 20 ]; then
            sudo sync 2>/dev/null
            echo 3 | sudo tee /proc/sys/vm/drop_caches >/dev/null 2>&1
        fi
    fi
fi
if command -v docker >/dev/null 2>&1; then
    echo "Limpiando datos de Docker..."
    docker system prune -af 2>/dev/null || true
fi

shutdown now
